# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=Zircon FRT
DEBUG=false
SECRET_KEY=change-me-in-production-use-a-strong-32-char-secret

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
POSTGRES_USER=zircon
POSTGRES_PASSWORD=zircon_secure_password
POSTGRES_DB=zircon
DATABASE_URL=postgresql+asyncpg://zircon:zircon_secure_password@postgres:5432/zircon
DATABASE_URL_SYNC=postgresql://zircon:zircon_secure_password@postgres:5432/zircon

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Elasticsearch ────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX=zircon_files

# ─── ClamAV ───────────────────────────────────────────────────────────────────
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# ─── Encryption (AES-256) ─────────────────────────────────────────────────────
# Generate with: python3 -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# ─── File Upload ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600  # 100 MB

# ─── JWT ──────────────────────────────────────────────────────────────────────
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 hours

# ─── Nginx ────────────────────────────────────────────────────────────────────
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
